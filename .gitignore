# ============================================================================

# VS Code
.vscode/
*.code-workspace
.history/

# JetBrains
.idea/
*.iml
*.iws
*.ipr
.DS_Store

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

